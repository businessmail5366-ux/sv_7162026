{
  "unet": {
    "class_type": "UNETLoader",
    "inputs": {
      "unet_name": "krea2_turbo_bf16.safetensors",
      "weight_dtype": "default"
    }
  },
  "clip": {
    "class_type": "CLIPLoader",
    "inputs": {
      "clip_name": "qwen3vl_4b_bf16.safetensors",
      "type": "krea2",
      "device": "default"
    }
  },
  "vae": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "qwen_image_vae.safetensors"
    }
  },
  "lora_1": {
    "class_type": "LoraLoader",
    "inputs": {
      "model": ["unet", 0],
      "clip": ["clip", 0],
      "lora_name": "Krea2/realism_engine_krea2_v3.1.safetensors",
      "strength_model": 1.0,
      "strength_clip": 1.0
    }
  },
  "lora_2": {
    "class_type": "LoraLoader",
    "inputs": {
      "model": ["lora_1", 0],
      "clip": ["lora_1", 1],
      "lora_name": "Krea2/RealisticSnapshotKrea2.safetensors",
      "strength_model": 0.8,
      "strength_clip": 0.8
    }
  },
  "pos": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "",
      "clip": ["lora_2", 1]
    }
  },
  "neg": {
    "class_type": "ConditioningZeroOut",
    "inputs": {
      "conditioning": ["pos", 0]
    }
  },
  "latent": {
    "class_type": "EmptySD3LatentImage",
    "inputs": {
      "width": 896,
      "height": 1152,
      "batch_size": 1
    }
  },
  "sampler": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["lora_2", 0],
      "positive": ["pos", 0],
      "negative": ["neg", 0],
      "latent_image": ["latent", 0],
      "seed": 0,
      "steps": 8,
      "cfg": 1.0,
      "sampler_name": "dpmpp_2m_sde_gpu",
      "scheduler": "sgm_uniform",
      "denoise": 0.7
    }
  },
  "decode": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["sampler", 0],
      "vae": ["vae", 0]
    }
  },
  "save": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["decode", 0],
      "filename_prefix": "krea2"
    }
  }
}
